# ============================================
# AI Reviewer Environment Configuration
# Copy this file to .env and fill in real values
# ============================================

# Database (used by both Docker Compose and the app)
DB_PASSWORD=YOUR_DB_PASSWORD
ConnectionStrings__VectorDb=Host=localhost;Port=5434;Database=ai_reviewer;Username=postgres;Password=YOUR_DB_PASSWORD

# GitHub
GitHub__AccessToken=ghp_your_github_personal_access_token
GitHub__Repository=your-org/your-repo

# OpenAI
OpenAI__ApiKey=sk-your-openai-api-key
OpenAI__Model=gpt-4o
